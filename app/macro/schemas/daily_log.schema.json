{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "daily_log",
  "title": "DailyLog",
  "description": "The full cumulative log for a single calendar day (today-log.json).",
  "type": "object",
  "required": ["date", "status", "timezone", "regimeMode", "lastUpdated", "entries"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date string (YYYY-MM-DD) for the day this log covers."
    },
    "status": {
      "type": "string",
      "enum": ["active", "finalized"]
    },
    "timezone": {
      "type": "string",
      "const": "America/New_York"
    },
    "regimeMode": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "description": "NarrativeEntry array, newest entry first.",
      "items": {
        "$ref": "narrative_entry.schema.json"
      }
    }
  }
}
