# Copy to .env and fill in your Plaid credentials
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Optional (for OAuth institutions)
# PLAID_REDIRECT_URI=https://your-domain.com/plaid/oauth-return

# Backend server
PORT=8787

# Comma-separated allowlist for your frontend origins
CORS_ORIGINS=http://localhost:5173,https://fortifyos.github.io

# Frontend: set this in Vite env (e.g. .env.local)
# VITE_PLAID_API_BASE=http://localhost:8787
