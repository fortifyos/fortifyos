{
  "name": "fortifyos-knox",
  "private": true,
  "version": "3.0.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "echo \"(optional) add eslint\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:pages": "DEPLOY_TARGET=pages npm run deploy",
    "cap:init": "npx cap init fortifyos io.fortifyos.knox --web-dir dist",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/secure-storage": "npm:capacitor-secure-storage-plugin@^0.13.0",
    "@capacitor/core": "^6.0.0",
    "@capgo/capacitor-native-biometric": "8.4.2",
    "dexie": "^4.0.10",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.2.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.21.0"
  }
}
